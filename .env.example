# =============================================================================
# Health Tracker Configuration
# Copy this file to .env and fill in your credentials
# =============================================================================

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_ACCESS_TOKEN=your_access_token
STRAVA_REFRESH_TOKEN=your_refresh_token

# Eight Sleep
EIGHT_SLEEP_EMAIL=your_email@example.com
EIGHT_SLEEP_PASSWORD=your_password
EIGHT_SLEEP_TIMEZONE=America/New_York
# Populated automatically on first auth; delete to force re-login with email+password.
EIGHT_SLEEP_REFRESH_TOKEN=
# Also cached automatically (refresh grants don't echo userId back).
EIGHT_SLEEP_USER_ID=
# Optional overrides (defaults ship with the Eight Sleep mobile app's public client id/secret).
EIGHT_SLEEP_CLIENT_ID=
EIGHT_SLEEP_CLIENT_SECRET=

# Whoop (https://developer.whoop.com) - enable when device arrives
WHOOP_ENABLED=false
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Weather (https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_api_key

# LLM Providers (configure whichever you want to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Default model for analysis
# Options: claude-sonnet, claude-opus, claude-haiku, gpt-4o, gpt-4o-mini, gemini-pro, gemini-flash
DEFAULT_LLM_PROVIDER=claude-sonnet

# App Settings
# Leave DATABASE_URL unset to use the default: ~/.health-tracker/health_tracker.db
# DATABASE_URL=sqlite+aiosqlite:///./health_tracker.db
SYNC_INTERVAL_HOURS=2
HOST=0.0.0.0
PORT=8000

# Tailscale hostname for CORS (e.g. my-mac.tailXXXXX.ts.net)
# See deploy/README.md for the always-on setup guide
TAILSCALE_HOSTNAME=

# Tailscale hostname for CORS (e.g. my-mac.tailXXXXX.ts.net)
# See deploy/README.md for the always-on setup guide
TAILSCALE_HOSTNAME=
