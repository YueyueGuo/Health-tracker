# =============================================================================
# Health Tracker Configuration
# Copy this file to .env and fill in your credentials
# =============================================================================

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# Eight Sleep
EIGHT_SLEEP_EMAIL=
EIGHT_SLEEP_PASSWORD=
EIGHT_SLEEP_TIMEZONE=America/New_York

# Whoop (https://developer.whoop.com) - enable when device arrives
WHOOP_ENABLED=false
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Weather (https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=

# LLM Providers (configure whichever you want to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Default model for analysis
# Options: claude-sonnet, claude-opus, claude-haiku, gpt-4o, gpt-4o-mini, gemini-pro, gemini-flash
DEFAULT_LLM_PROVIDER=claude-sonnet

# Telegram Bot (https://core.telegram.org/bots#botfather)
TELEGRAM_BOT_TOKEN=

# Discord Bot (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# App Settings
DATABASE_URL=sqlite+aiosqlite:///./health_tracker.db
SYNC_INTERVAL_HOURS=2
HOST=0.0.0.0
PORT=8000
